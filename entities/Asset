{
  "name": "Asset",
  "type": "object",
  "properties": {
    "tag": {
      "type": "string",
      "description": "C\u00f3digo patrimonial / etiqueta do ativo"
    },
    "name": {
      "type": "string",
      "description": "Nome do equipamento"
    },
    "category": {
      "type": "string",
      "enum": [
        "notebook",
        "monitor",
        "tv",
        "desktop",
        "impressora",
        "telefone",
        "headset",
        "teclado",
        "mouse",
        "nobreak",
        "switch",
        "roteador",
        "servidor",
        "tablet",
        "outros"
      ],
      "description": "Categoria do equipamento"
    },
    "brand": {
      "type": "string",
      "description": "Marca do equipamento"
    },
    "model": {
      "type": "string",
      "description": "Modelo do equipamento"
    },
    "serial_number": {
      "type": "string",
      "description": "N\u00famero de s\u00e9rie"
    },
    "status": {
      "type": "string",
      "enum": [
        "disponivel",
        "em_uso",
        "manutencao",
        "descartado"
      ],
      "default": "disponivel",
      "description": "Status do ativo"
    },
    "condition": {
      "type": "string",
      "enum": [
        "novo",
        "bom",
        "regular",
        "ruim"
      ],
      "default": "novo",
      "description": "Estado de conserva\u00e7\u00e3o"
    },
    "unit_id": {
      "type": "string",
      "description": "ID da unidade/filial onde o ativo est\u00e1 alocado"
    },
    "unit_name": {
      "type": "string",
      "description": "Nome da unidade/filial (desnormalizado para exibi\u00e7\u00e3o)"
    },
    "purchase_date": {
      "type": "string",
      "format": "date",
      "description": "Data de aquisi\u00e7\u00e3o"
    },
    "purchase_value": {
      "type": "number",
      "description": "Valor de aquisi\u00e7\u00e3o (R$)"
    },
    "location": {
      "type": "string",
      "description": "Localiza\u00e7\u00e3o interna (setor/sala)"
    },
    "assigned_to": {
      "type": "string",
      "description": "Nome do colaborador respons\u00e1vel"
    },
    "assigned_to_email": {
      "type": "string",
      "description": "Email do colaborador respons\u00e1vel"
    },
    "assigned_to_cpf": {
      "type": "string",
      "description": "CPF do colaborador respons\u00e1vel"
    },
    "assigned_to_department": {
      "type": "string",
      "description": "Departamento do colaborador"
    },
    "assignment_date": {
      "type": "string",
      "format": "date",
      "description": "Data da atribui\u00e7\u00e3o"
    },
    "notes": {
      "type": "string",
      "description": "Observa\u00e7\u00f5es"
    },
    "image_url": {
      "type": "string",
      "description": "Foto do equipamento"
    }
  },
  "required": [
    "name",
    "category",
    "status"
  ]
}
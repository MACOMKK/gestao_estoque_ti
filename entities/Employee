{
  "name": "Employee",
  "type": "object",
  "properties": {
    "full_name": {
      "type": "string",
      "description": "Nome completo do colaborador"
    },
    "cpf": {
      "type": "string",
      "description": "CPF do colaborador"
    },
    "email": {
      "type": "string",
      "description": "Email corporativo"
    },
    "phone": {
      "type": "string",
      "description": "Telefone"
    },
    "department": {
      "type": "string",
      "enum": [
        "TI",
        "Administrativo",
        "Financeiro",
        "Comercial",
        "RH",
        "P\u00f3s-Vendas",
        "Diretoria",
        "Marketing",
        "Opera\u00e7\u00f5es",
        "Outro"
      ],
      "description": "Departamento"
    },
    "role": {
      "type": "string",
      "description": "Cargo"
    },
    "unit_id": {
      "type": "string",
      "description": "ID da unidade/filial do colaborador"
    },
    "unit_name": {
      "type": "string",
      "description": "Nome da unidade/filial (desnormalizado)"
    },
    "admission_date": {
      "type": "string",
      "format": "date",
      "description": "Data de admiss\u00e3o"
    },
    "status": {
      "type": "string",
      "enum": [
        "ativo",
        "inativo"
      ],
      "default": "ativo",
      "description": "Status do colaborador"
    },
    "termo_assinado": {
      "type": "boolean",
      "default": false,
      "description": "Indica se o colaborador j\u00e1 assinou o termo de posse"
    },
    "termo_assinado_em": {
      "type": "string",
      "format": "date",
      "description": "Data em que o termo foi assinado"
    }
  },
  "required": [
    "full_name",
    "department"
  ]
}